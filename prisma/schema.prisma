generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"] // Añade esto
  engineType      = "library"          // Y añade esto también
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  cedula    String   @unique
  password  String
  nombre    String?
  rol       String   @default("VENDEDOR")
  estado    String   @default("Activo")
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendedor  Vendedor?
  @@map("usuarios")
}

model Vendedor {
  id               Int         @id @default(autoincrement())
  cedula           String      @unique
  nombre           String
  apellido         String?
  puntosAcumulados Decimal     @default(0.00) @db.Decimal(10, 2)
  saldoGastado     Decimal     @default(0.00) @db.Decimal(10, 2)
  activo           Boolean     @default(true)
  usuarioId        Int?        @unique
  usuario          User?       @relation(fields: [usuarioId], references: [id])
  evidencias       Evidencia[]
  canjes           Canje[]     
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@map("vendedores")
}
model Campana {
  id          Int         @id @default(autoincrement())
  nombre      String
  descripcion String?     @db.Text
  fechaInicio DateTime
  fechaFin    DateTime
  activa      Boolean     @default(true)
  evidencias  Evidencia[]
  createdAt   DateTime    @default(now())
  urlImagen   String?
  valor Float @default(0)
  @@map("campanas") 
}

model Evidencia {
  id             Int      @id @default(autoincrement())
  urlImagen      String
  publicId       String
  clienteNombre  String
  vendedorId     Int
  vendedor       Vendedor @relation(fields: [vendedorId], references: [id])
  campanaId      Int
  campana        Campana  @relation(fields: [campanaId], references: [id])
  valorPagado    Float    @default(2.00)
  estado         String   @default("pendiente") // pendiente, aprobado, rechazado
  motivoRechazo  String?  
  imageHash     String?  @unique 
  createdAt      DateTime @default(now())
}
model Premio {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String?
  puntos      Float    
  urlImagen   String
  publicId    String
  stock       Int      @default(1)
  activo      Boolean  @default(true)
  reservado   Boolean  @default(false)
  canjes      Canje[] 
  createdAt   DateTime @default(now())
}
model Canje {
  id          Int      @id @default(autoincrement())
  vendedorId  Int
  premioId    Int
  vendedor    Vendedor @relation(fields: [vendedorId], references: [id])
  premio      Premio   @relation(fields: [premioId], references: [id])
  estado      String   @default("pendiente") 
  createdAt   DateTime @default(now())
}